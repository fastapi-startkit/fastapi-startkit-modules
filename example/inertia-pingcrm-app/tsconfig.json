{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./resources/js/*"]
    },
    "baseUrl": ".",
    "types": ["vite/client", "node"]
  },
  "include": ["resources/js/**/*"],
  "exclude": ["node_modules"]
}